{
	"info": {
		"_postman_id": "cafe-system-collection",
		"name": "Cafe Management System API",
		"description": "Postman collection for all endpoints of the Cafe System.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"ten_dang_nhap\": \"admin\",\n    \"mat_khau\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login/",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "auth", "login", "" ]
						}
					}
				}
			]
		},
		{
			"name": "Menu",
			"item": [
				{
					"name": "Get Menu",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/menu/",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "menu", "" ]
						}
					}
				}
			]
		},
		{
			"name": "Tables",
			"item": [
				{
					"name": "Get Tables",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{base_url}}/api/tables/",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "tables", "" ]
						}
					}
				}
			]
		},
		{
			"name": "Orders",
			"item": [
				{
					"name": "Create Order",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"ma_ban\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/orders/",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "orders", "" ]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "token",
			"value": "YOUR_JWT_TOKEN",
			"type": "string"
		}
	]
}
